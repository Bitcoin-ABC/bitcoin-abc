# Cashtab Environment Variables
# Copy this file to .env and fill in your actual values

# Google Analytics
VITE_GOOGLE_ANALYTICS=your_google_analytics_tracking_id_here

# reCAPTCHA v2 (XEC welcome bonus)
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_v2_site_key_here

# reCAPTCHA v3 (Cachet token rewards)
# Web/extension: create a Website key with your domain(s) allowed.
# Android: create an Android app key with com.cashtab.app and com.cashtab.app.dev
# registered; the same site key is passed to the native SDK at runtime.
VITE_RECAPTCHA_V3_SITE_KEY=your_recaptcha_v3_site_key_here

# Displayed on Settings page
VITE_VERSION=$npm_package_version

# Run Cashtab for Testnet
VITE_TESTNET=false

# Build environment (set to 'extension' for extension builds)
VITE_BUILD_ENV=
