# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram channel ID for new token icon moderation notifications
TELEGRAM_CHANNEL_ID=your_telegram_channel_id_here

# Comma-separated Telegram user IDs authorized to deny/restore token icons
APPROVED_MODS=

# MongoDB connection string (TODO replace with DATABASE_URL)
MONGODB_URL=mongodb://username:password@localhost:27017
