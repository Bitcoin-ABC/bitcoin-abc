# Cashtab Faucet Environment Variables
# Copy this file to .env and fill in your actual values

# Hot wallet mnemonic for issuing token rewards
HOTWALLET_MNEMONIC=your_hotwallet_mnemonic_here

# reCAPTCHA v2 secret key (XEC welcome bonus)
RECAPTCHA_SK=your_recaptcha_v2_secret_key_here

# reCAPTCHA v3 secret key (Cachet token rewards, web/extension clients)
RECAPTCHA_V3_SK=your_recaptcha_v3_secret_key_here

# reCAPTCHA Enterprise (Cachet token rewards, Android native clients)
# CreateAssessment API — not the siteverify secret above
RECAPTCHA_PROJECT_ID=your_gcp_project_id
RECAPTCHA_ENTERPRISE_API_KEY=your_recaptcha_enterprise_api_key
RECAPTCHA_V3_ANDROID_SITE_KEY=your_android_recaptcha_site_key_here

# Minimum reCAPTCHA v3 score required to claim token rewards (0.0 to 1.0)
RECAPTCHA_V3_MIN_SCORE=0.9
