{
    "name": "alp-dex",
    "version": "0.1.0",
    "description": "Permissionless ALP AMM LP node with local-liquidity pricing",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc -p ./tsconfig.build.json",
        "start": "node dist/index.js",
        "dev": "tsx index.ts",
        "print-addresses": "tsx scripts/printHdAddresses.ts",
        "test": "mocha --import=tsx './test/**/*.test.ts'",
        "coverage": "c8 mocha --import=tsx './test/**/*.test.ts'",
        "junit": "mocha --import=tsx './test/**/*.test.ts' --reporter mocha-junit-reporter"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Bitcoin-ABC/bitcoin-abc.git",
        "directory": "apps/alp-dex"
    },
    "keywords": [
        "ecash",
        "ALP",
        "AMM",
        "XEC"
    ],
    "author": "Bitcoin ABC",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/Bitcoin-ABC/bitcoin-abc/issues"
    },
    "homepage": "https://github.com/Bitcoin-ABC/bitcoin-abc/tree/master/apps/alp-dex#readme",
    "engines": {
        "node": ">=20"
    },
    "dependencies": {
        "chronik-client": "workspace:^",
        "ecash-lib": "workspace:^",
        "ecash-wallet": "workspace:^",
        "express": "^5.2.1"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/mocha": "^10.0.10",
        "@types/node": "^22.15.0",
        "@types/supertest": "^6.0.3",
        "c8": "^10.1.3",
        "mocha": "^11.7.5",
        "mocha-junit-reporter": "^2.2.1",
        "mock-chronik-client": "workspace:^",
        "supertest": "^7.2.2",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
}
