{
    "compilerOptions": {
        "target": "es2020",
        "module": "commonjs",
        "outDir": "./dist",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "alwaysStrict": true,
        "skipLibCheck": true
    },
    "include": ["index.ts", "scripts/**/*", "src/**/*"],
    "exclude": ["dist", "**/*.test.ts", "scripts"]
}
