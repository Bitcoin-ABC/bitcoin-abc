# Cashtab Notifications Server Environment Variables
# Copy this file to .env and fill in the values
#
# Apply schema before starting:
#   psql $DATABASE_CONNECTION_STRING -f schema.sql

# Server Configuration
PORT=3020
NODE_ENV=development

# Database Configuration (PostgreSQL / Neon)
DATABASE_CONNECTION_STRING=postgresql://user:password@host:5432/database?sslmode=require

# Chronik indexer URLs — comma-separated, tried in order with failover
CHRONIK_URLS=https://chronik-native1.fabien.cash,https://chronik-native2.fabien.cash,https://chronik-native3.fabien.cash

# Firebase Cloud Messaging (push notifications to Cashtab mobile + web)
# Service account JSON from Firebase Console > Project settings > Service accounts
# Container path (bind-mount at deploy):
FIREBASE_SERVICE_ACCOUNT_PATH=/app/apps/notifications-server/firebase-service-account.json
# Local dev: place cashtab-push-firebase-adminsdk-*.json in this directory and set in .env:
# FIREBASE_SERVICE_ACCOUNT_PATH=./cashtab-push-firebase-adminsdk-fbsvc-xxxxxxxx.json
