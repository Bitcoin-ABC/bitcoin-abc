# Copy to .env before running the dev server:
#   cp env.sample .env

# Public site URL (metadata, social cards, FAQ links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Strapi CMS (blog posts, products). Required — next.config.ts fails to load without this.
NEXT_PUBLIC_STRAPI_URL=https://strapi.e.cash

# Scorecard API (exchanges, apps). Required — next.config.ts fails to load without this.
NEXT_PUBLIC_STRAPI_SCORECARD_URL=https://api.scorecard.cash

# Google Analytics (optional for local dev; only loaded in production)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
